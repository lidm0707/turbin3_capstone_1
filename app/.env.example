```# Solana Network Configuration
# Default network to use when the app first loads
# Options: "devnet", "mainnet", "localnet"
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Custom RPC Endpoints (Optional)
# Use private RPC endpoints for production to avoid rate limits
# Get endpoints from: Helius, QuickNode, Alchemy, etc.

# Mainnet RPC endpoint (for production)
NEXT_PUBLIC_MAINNET_RPC=https://api.mainnet-beta.solana.com

# Devnet RPC endpoint (for testing)
NEXT_PUBLIC_DEVNET_RPC=https://api.devnet.solana.com

# Localnet RPC endpoint (for development)
NEXT_PUBLIC_LOCALNET_RPC=http://127.0.0.1:8899

# Optional: Analytics and Monitoring
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true
